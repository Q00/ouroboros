# Ouroboros Environment Configuration
# Copy this file to .env (project-local) or ~/.ouroboros/.env (user-global)
# and uncomment the lines you want to override. Project-local .env wins.
#
# Resolution order for every value: env var -> ~/.ouroboros/config.yaml -> hardcoded default.

# =============================================================================
# LLM Provider API Keys
# =============================================================================

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google (for Gemini)
# GOOGLE_API_KEY=...

# OpenRouter (for accessing multiple providers)
# OPENROUTER_API_KEY=sk-or-...

# =============================================================================
# Model Policy
# =============================================================================
# Ouroboros routes different pipeline roles to different model tiers:
#   Reasoning  (Opus)   - evolutionary introspection where depth matters
#   Worker     (Sonnet) - analysis/planning/evaluation; most of the pipeline
#   Extraction (Haiku)  - structured classification and compression
#
# The defaults below reflect the shipped policy. Uncomment only to override.

# --- Reasoning (Opus) -------------------------------------------------------
# Wonder: open-question generation in the evolutionary loop
# OUROBOROS_WONDER_MODEL=claude-opus-4-6
# Reflect: ontology/AC mutation proposals in the evolutionary loop
# OUROBOROS_REFLECT_MODEL=claude-opus-4-6
# Clarification: Socratic interview / seed generation
# OUROBOROS_CLARIFICATION_MODEL=claude-opus-4-6

# --- Worker (Sonnet) --------------------------------------------------------
# Post-execution quality assurance verdict
# OUROBOROS_QA_MODEL=claude-sonnet-4-6
# Acceptance-criteria dependency graph analysis
# OUROBOROS_DEPENDENCY_ANALYSIS_MODEL=claude-sonnet-4-6
# Ontological consistency analysis
# OUROBOROS_ONTOLOGY_ANALYSIS_MODEL=claude-sonnet-4-6
# Acceptance-criteria decomposition into sub-ACs
# OUROBOROS_DECOMPOSITION_MODEL=claude-sonnet-4-6
# Double Diamond design-phase default
# OUROBOROS_DOUBLE_DIAMOND_MODEL=claude-sonnet-4-6
# Stage-2 semantic evaluation
# OUROBOROS_SEMANTIC_MODEL=claude-sonnet-4-6

# --- Extraction (Haiku) -----------------------------------------------------
# AC atomicity classification (also feeds adaptive executor routing)
# OUROBOROS_ATOMICITY_MODEL=claude-haiku-4-5-20251001
# Verification assertion extraction
# OUROBOROS_ASSERTION_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# Workflow context compression
# OUROBOROS_CONTEXT_COMPRESSION_MODEL=claude-haiku-4-5-20251001

# =============================================================================
# Executor (per-AC) Model — Adaptive by default
# =============================================================================
# The executor runs the actual code-writing agent for each acceptance criterion.
# By default it adapts per AC using the atomicity/complexity signal:
#   complexity=simple  -> frugal tier (Haiku)
#   complexity=normal  -> standard tier (Sonnet)
#   complexity=complex -> standard tier (Sonnet; Opus only via explicit override)
#
# Two escape hatches (checked in this order):

# Pin the executor to a specific model, ignoring the adaptive policy and tier.
# OUROBOROS_EXECUTOR_MODEL=claude-sonnet-4-6

# Pin the executor to a tier (frugal | standard | frontier).
# The adapter still picks a model from that tier but complexity is ignored.
# OUROBOROS_EXECUTOR_TIER=standard

# =============================================================================
# Consensus (Stage 3) Models
# =============================================================================
# Comma-separated roster for the voting stage.
# OUROBOROS_CONSENSUS_MODELS=openrouter/openai/gpt-4o,openrouter/anthropic/claude-opus-4-6,openrouter/google/gemini-2.5-pro
# OUROBOROS_CONSENSUS_ADVOCATE_MODEL=openrouter/anthropic/claude-opus-4-6
# OUROBOROS_CONSENSUS_DEVIL_MODEL=openrouter/openai/gpt-4o
# OUROBOROS_CONSENSUS_JUDGE_MODEL=openrouter/google/gemini-2.5-pro

# =============================================================================
# Behavior Toggles — Centralize defaults for ooo run / ooo ralph
# =============================================================================
# Each toggle applies only when the caller doesn't pass the argument explicitly.
# Passing a value via the MCP tool or CLI always wins over the env var.

# Run ACs in parallel (true) or serial (false). Serial is slower but more stable.
# OUROBOROS_PARALLEL=true

# Skip the auto-QA pass after successful execution. Saves ~2.5k tokens per run.
# OUROBOROS_SKIP_QA=false

# Ralph max iterations (safety cap on the evolutionary loop).
# OUROBOROS_RALPH_MAX_ITERATIONS=10

# Enable AC decomposition. Disable for small/simple seeds to save tokens.
# OUROBOROS_ENABLE_DECOMPOSITION=true

# Maximum recursion depth when decomposing ACs into sub-ACs.
# OUROBOROS_MAX_DECOMPOSITION_DEPTH=2

# =============================================================================
# Orchestrator / Runtime
# =============================================================================

# Agent runtime backend: claude | codex | opencode
# OUROBOROS_AGENT_RUNTIME=claude
# Agent permission mode: default | acceptEdits | bypassPermissions
# OUROBOROS_AGENT_PERMISSION_MODE=acceptEdits

# LLM-only backend (used for analysis calls that don't need agent tools).
# OUROBOROS_LLM_BACKEND=claude_code
# OUROBOROS_LLM_PERMISSION_MODE=default
# OUROBOROS_OPENCODE_PERMISSION_MODE=acceptEdits

# Custom CLI paths (absolute or ~ expanded). Leave unset to use SDK defaults.
# OUROBOROS_CLI_PATH=/path/to/your/custom-claude
# OUROBOROS_CODEX_CLI_PATH=/path/to/codex
# OUROBOROS_OPENCODE_CLI_PATH=/path/to/opencode
# OUROBOROS_GEMINI_CLI_PATH=/path/to/gemini

# Preferred MCP web-search tool name used during interview mode.
# OUROBOROS_WEB_SEARCH_TOOL=mcp__tavily__search

# =============================================================================
# Logging
# =============================================================================

# Log mode: dev (human-readable) or prod (JSON)
# OUROBOROS_LOG_MODE=dev

# =============================================================================
# MCP Configuration (Optional)
# =============================================================================
# MCP servers are configured in ~/.claude/.mcp.json.
# Ouroboros inherits MCP settings from Claude Code when using --orchestrator mode.
